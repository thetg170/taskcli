# Credentials only. Task/project/work ids should be passed as CLI flags.
BECA_USERNAME=your_username
BECA_PASSWORD=your_password
# BECA_COOKIE=your_cookie_here

# taskcli defaults. Flags override these.
TASKCLI_TIMEOUT=30
TASKCLI_VERBOSE=false

# Assignee defaults to the logged-in BecaWork user.
# Use `uv run taskcli whoami --json` to check the resolved id.
